{
  "name": "gaia-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build && tsc -p tsconfig.server.json",
    "db:init": "npm run build && node dist/server/db/init.js",
    "dev": "vite --host 127.0.0.1",
    "start": "npm run build && node dist/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run build && npm test && npm run test:e2e"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
